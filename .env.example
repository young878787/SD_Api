# Nvidia API 配置
# 從 https://build.nvidia.com/ 獲取 API Key
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# ============================================
# 🔧 多模型備用機制（新功能）
# ============================================


# ── Google Gemini API ─────────────────────────────────────────
# 從 https://aistudio.google.com/apikey 獲取
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# 最新模型：gemini-3-flash-preview（Gemini 3 Flash）
# 穩定版模型：gemini-2.5-flash
GEMINI_MODEL_NAME=gemini-3-flash-preview
GEMINI_BACKUP_MODELS=gemini-2.5-flash
GEMINI_API_TIMEOUT=60

# 主要模型（優先使用）
NVIDIA_MODEL_NAME=qwen3-next-80b-a3b-instruct
# 備用模型列表（用逗號或分號分隔，從左到右依序嘗試）
# 當主模型失敗或超時時，會自動切換到備用模型
# 範例模型：
# - openai/gpt-oss-120b (速度快，品質普通，適合快速回應)
# - qwen3-next-80b-a3b-instruct (穩定可靠 我自用的主力模型)
# - meta/llama-3.1-405b-instruct (效果最好但較慢)
NVIDIA_BACKUP_MODELS=openai/gpt-oss-120b,nvidia/llama-3.1-nemotron-70b-instruct

# API 超時設定（秒）
# 超過此時間未回應，會自動切換到下一個模型
# 建議設定：30-120 秒（根據網路速度調整）
NVIDIA_API_TIMEOUT=60

# ============================================
# 📝 使用說明
# ============================================
# 1. 主模型會優先使用
# 2. 如果主模型失敗或超時，會依序嘗試備用模型
# 3. 所有模型都失敗後才會返回錯誤
# 4. 程式會顯示每個模型的使用狀況和回應時間

# 以下為舊版 GitHub Models 配置（已棄用）
# GITHUB_TOKEN=your_github_token_here
